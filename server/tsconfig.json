{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "types": ["node"]
  },
  "include": ["**/*.ts", "../src/shared/**/*.ts", "../src/data/content.ts", "../src/lib/date.ts"],
  "exclude": ["../src/shared/**/*.test.ts"]
}
